generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id
  email     String   @unique
  fullName  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  videos    Video[]
}

model Video {
  id           String      @id @default(cuid())
  topic        String
  script       String?
  visualPrompt String?
  audioUrl     String?
  videoUrl     String?
  finalUrl     String?
  error        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  style        String      @default("Cinematic")
  status       VideoStatus @default(queued)
  captions     Boolean     @default(true)
  voiceId      String      @default("")
  modelId      String      @default("fast-wan")
  resolution   String      @default("480p")
  userId       String?
  user         User?       @relation(fields: [userId], references: [id])
}

enum VideoStatus {
  queued
  scripting
  voicing
  generating
  merging
  completed
  failed
}
